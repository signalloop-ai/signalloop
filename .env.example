# Local Postgres or Supabase Postgres connection string.
# For Render + Supabase, set this to the Supabase pooler or direct Postgres URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signalloop

SIGNALLOOP_ENV=local
PUBLIC_BASE_URL=http://127.0.0.1:3000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_JWKS_URL=

# Execution backend: direct (in-process, no infra), http_worker, or ecs_fargate
EXECUTION_BACKEND=direct
EXECUTION_WORKER_URL=http://localhost:9000
ASSESSMENT_RUNTIME_IMAGE=signalloop-python-assessment:3.11
WORKER_REQUEST_TIMEOUT_SECONDS=90
WORKER_REQUEST_RETRIES=1
WORKER_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# Comma-separated list of email addresses that get super_admin role on login.
SUPER_ADMIN_EMAILS=
