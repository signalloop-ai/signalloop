{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunAndObserveRunnerTasks",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTasks",
        "ecs:RunTask",
        "ecs:StopTask"
      ],
      "Resource": [
        "arn:aws:ecs:ap-south-1:ACCOUNT_ID:cluster/signalloop",
        "arn:aws:ecs:ap-south-1:ACCOUNT_ID:task-definition/signalloop-assessment-runner:*",
        "arn:aws:ecs:ap-south-1:ACCOUNT_ID:task/signalloop/*"
      ]
    },
    {
      "Sid": "PassRunnerRolesToEcsTasks",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
        "arn:aws:iam::ACCOUNT_ID:role/SignalLoopRunnerTaskRole"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    },
    {
      "Sid": "ListRunnerPrefixOnly",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::SIGNALLOOP_RUN_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "runs",
            "runs/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteRunnerPrefixObjects",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:GetObjectAttributes",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::SIGNALLOOP_RUN_BUCKET/runs/*"
    }
  ]
}
