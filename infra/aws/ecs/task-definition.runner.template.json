{
  "family": "signalloop-assessment-runner",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/signalloop-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/signalloop-assessment-runner-task-role",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "runner",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/signalloop-assessment-runner:latest",
      "essential": true,
      "environment": [
        {
          "name": "SIGNALLOOP_RUNNER_INPUT",
          "value": "s3://SIGNALLOOP_RUN_BUCKET/runs/example/input.json"
        },
        {
          "name": "SIGNALLOOP_RUNNER_OUTPUT",
          "value": "s3://SIGNALLOOP_RUN_BUCKET/runs/example/output.json"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/signalloop-assessment-runner",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "runner"
        }
      },
      "readonlyRootFilesystem": false
    }
  ]
}
