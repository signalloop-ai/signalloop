# Render + Supabase + Clerk pilot deployment values.
# Do not commit real secrets. Use these keys in Render service environment settings.

SIGNALLOOP_ENV=pilot

# Supabase Postgres.
# Use the Supabase direct URL if reachable, or the session pooler URL for IPv4-only hosting.
# Example session pooler shape:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Render service URLs.
RENDER_WEB_URL=https://YOUR-WEB-SERVICE.onrender.com
RENDER_API_URL=https://YOUR-API-SERVICE.onrender.com

# API service uses these provider-neutral values.
PUBLIC_BASE_URL=https://YOUR-WEB-SERVICE.onrender.com
CORS_ORIGINS=https://YOUR-WEB-SERVICE.onrender.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Phase 11 pilot execution.
# Local/staging worker can be used only for controlled testing.
# Production candidate execution should move to ECS/Fargate per ADR 0006.
EXECUTION_WORKER_URL=
ASSESSMENT_RUNTIME_IMAGE=signalloop-python-assessment:3.11
WORKER_REQUEST_TIMEOUT_SECONDS=90
WORKER_REQUEST_RETRIES=1

# AWS ECS/Fargate execution scaffold.
# These are not used by the current HTTP worker path until the API ECS provider is implemented.
AWS_REGION=
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ECR_RUNNER_REPOSITORY=signalloop-assessment-runner
AWS_ECS_CLUSTER=
AWS_ECS_RUNNER_TASK_DEFINITION=signalloop-assessment-runner
AWS_ECS_RUNNER_CONTAINER=runner
AWS_ECS_SUBNET_IDS=
AWS_ECS_SECURITY_GROUP_IDS=
AWS_ECS_ASSIGN_PUBLIC_IP=DISABLED
SIGNALLOOP_RUN_BUCKET=

# Web service uses these public client-side values.
NEXT_PUBLIC_API_URL=https://YOUR-API-SERVICE.onrender.com

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
